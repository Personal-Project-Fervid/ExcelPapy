<UserControl
    x:Class="ExcelPapy.Objects.SliderCustom"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ExcelPapy.Objects"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid  x:Name="RootGrid" SizeChanged="RootGrid_SizeChanged">
        <Border HorizontalAlignment="Stretch" Height="10" CornerRadius="5" Background="#A0E8CFAC"/>
        <Border x:Name="Track" HorizontalAlignment="Left" Height="10" CornerRadius="5" Background="#BFBFBF"/>
        <Grid x:Name="Thumb" Height="15" Width="32"
              HorizontalAlignment="Left"
              PointerPressed="Thumb_PointerPressed"
              PointerMoved="Thumb_PointerMoved"
              PointerReleased="Thumb_PointerReleased"
              PointerCaptureLost="Thumb_PointerCaptureLost">
            <Border Background="#F0C775" Width="32" Height="15" CornerRadius="5"/>
            <Canvas>
                <Line X1="8" Y1="3" X2="8" Y2="12" Stroke="#292828" StrokeThickness="2"/>
                <Line X1="16" Y1="3" X2="16" Y2="12" Stroke="#292828" StrokeThickness="2"/>
                <Line X1="24" Y1="3" X2="24" Y2="12" Stroke="#292828" StrokeThickness="2"/>
            </Canvas>
        </Grid>
    </Grid>
    
</UserControl>

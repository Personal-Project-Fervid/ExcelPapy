<UserControl
    x:Class="ExcelPapy.Objects.CellPersonalization"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ExcelPapy.Objects"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Border Background="#E6E6E6" CornerRadius="15" BorderBrush="Black" BorderThickness="3">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HorizontalAlignment = Left -->
            <Button Tag="Left" Click="OnHorizontalAlignmentSelected" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="0" Grid.Column="0" Background="Transparent" Style="{StaticResource ButtonPersonalization}">
                <Grid Margin="0,7,0,-7">
                    <Line X1="0" Y1="4" X2="30" Y2="4" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="12" X2="20" Y2="12" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="20" X2="30" Y2="20" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="28" X2="20" Y2="28" Stroke="Black" StrokeThickness="3"/>
                </Grid>
            </Button>

            <!-- HorizontalAlignment = Center -->
            <Button Tag="Center" Click="OnHorizontalAlignmentSelected" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="0" Grid.Column="1" Background="Transparent" Style="{StaticResource ButtonPersonalization}">
                <Grid Margin="0,7,0,-7">
                    <Line X1="0" Y1="4" X2="30" Y2="4" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="5" Y1="12" X2="25" Y2="12" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="20" X2="30" Y2="20" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="5" Y1="28" X2="25" Y2="28" Stroke="Black" StrokeThickness="3"/>
                </Grid>
            </Button>

            <!-- HorizontalAlignment = Right -->
            <Button Tag="Right" Click="OnHorizontalAlignmentSelected" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="0" Grid.Column="2" Background="Transparent" Style="{StaticResource ButtonPersonalization}">
                <Grid Margin="0,7,0,-7">
                    <Line X1="0" Y1="4" X2="30" Y2="4" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="10" Y1="12" X2="30" Y2="12" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="20" X2="30" Y2="20" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="10" Y1="28" X2="30" Y2="28" Stroke="Black" StrokeThickness="3"/>
                </Grid>
            </Button>

            <!-- VerticalAlignment = Top -->
            <Button Tag="Top" Click="OnVerticalAlignmentSelected" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="1" Grid.Column="0" Background="Transparent" Style="{StaticResource ButtonPersonalization}">
                <Grid Margin="0,15,0,-15">
                    <Line X1="0" Y1="-8" X2="30" Y2="-8" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="5" Y1="0" X2="25" Y2="0" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="8" X2="30" Y2="8" Stroke="Black" StrokeThickness="3"/>
                </Grid>
            </Button>

            <!-- VerticalAlignment = Center -->
            <Button Tag="Center" Click="OnVerticalAlignmentSelected" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="1" Grid.Column="1" Background="Transparent" Style="{StaticResource ButtonPersonalization}">
                <Grid Margin="0,12,0,-12">
                    <Line X1="0" Y1="2" X2="30" Y2="2" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="5" Y1="10" X2="25" Y2="10" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="18" X2="30" Y2="18" Stroke="Black" StrokeThickness="3"/>
                </Grid>
            </Button>

            <!-- VerticalAlignment = Bottom -->
            <Button Tag="Bottom" Click="OnVerticalAlignmentSelected" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="1" Grid.Column="2" Background="Transparent" Style="{StaticResource ButtonPersonalization}">
                <Grid Margin="0,10,0,-10">
                    <Line X1="0" Y1="12" X2="30" Y2="12" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="5" Y1="20" X2="25" Y2="20" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="28" X2="30" Y2="28" Stroke="Black" StrokeThickness="3"/>
                </Grid>
            </Button>

            <!-- Bordure -->
            <Grid Grid.Column="3" Grid.ColumnSpan="5" Margin="5">
                <!-- Bouton qui affiche la sélection actuelle -->
                <Border x:Name="BorderPickerButton"  Background="White" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" CornerRadius="15" BorderThickness="3" BorderBrush="Black"/>

                <Button Click="OnBorderPickerClick" Margin="258,6,6,6" Style="{StaticResource ButtonPersonalizationArrow}">
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                       
                        <Grid Height="24" Width="24" HorizontalAlignment="Right" Margin="-8,0,8,0">
                            <Line X1="0" Y1="6" X2="12" Y2="18" Stroke="Black" StrokeThickness="3"/>
                            <Line X1="12" Y1="18" X2="12" Y2="19" Stroke="Black" StrokeThickness="3"/>
                            <Line X1="12" Y1="18" X2="23" Y2="6" Stroke="Black" StrokeThickness="3"/>
                        </Grid>
                    </Grid>
                </Button>
                <Line Stroke="Black" StrokeThickness="3" X1="253" Y1="6" X2="253" Y2="40"/>
                <Button Click="BorderPersonalization" Width="253" Style="{StaticResource ButtonPersonalizationPopup}"/>
                
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left" Margin="0,0,0,0" Width="244" Height="26" IsHitTestVisible="False">
                    <Rectangle Width="10" Height="10" Fill="Transparent"/>
                    <Canvas x:Name="SelectedBorderIcon" Width="24" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Mis à jour par code-behind selon la sélection -->
                    </Canvas>
                    <TextBlock x:Name="SelectedBorderText" Text="Bordure..." FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Popup avec les choix -->
                <Popup x:Name="BorderPickerPopup"
                       IsLightDismissEnabled="True"
                       PlacementTarget="{Binding ElementName=BorderPickerButton}"
                       DesiredPlacement="Bottom"
                       Opened="BorderPickerPopup_Opened"
                       Closed="BorderPickerPopup_Closed">
                    
                    <Border x:Name="BorderPickerBorder"
                            Margin="0,3,0,-3"
                            BorderBrush="Black"
                            BorderThickness="3"
                            CornerRadius="15"
                            MinWidth="{Binding ActualWidth, ElementName=BorderPickerButton}">
                        
                        <Grid>
                            <Border x:Name="BlurredBorderContainertransition" CornerRadius="13" Margin="-3" Background="#80FFFFFF"/>
                            <Border x:Name="BlurredBorderContainer" CornerRadius="13" Margin="-3">
                                <Border.Background>
                                    <ImageBrush x:Name="BlurredBorderBackgroundBrush" Stretch="Fill" />
                                </Border.Background>
                            </Border>

                            <Border Background="#A0FFFFFF" CornerRadius="13"/>
                            
                            <StackPanel Padding="5" Spacing="7">

                                <Button Click="OnBorderSelected" Tag="Top" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Style="{StaticResource NumberFontSize}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Canvas Width="24" Height="24" HorizontalAlignment="Left">
                                            <Line X1="0" X2="24" Y1="0" Y2="0" Stroke="Black" StrokeThickness="2"/>
                                            <Line X1="0" X2="24" Y1="12" Y2="12" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="24" Y1="24" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="0" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="12" X2="12" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="24" X2="24" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                        </Canvas>
                                        <TextBlock Text="Bordure supérieure" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Click="OnBorderSelected" Tag="Left" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Style="{StaticResource NumberFontSize}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Canvas Width="24" Height="24" HorizontalAlignment="Left">
                                            <Line X1="0" X2="24" Y1="0" Y2="0" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="24" Y1="12" Y2="12" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="24" Y1="24" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="0" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2"/>
                                            <Line X1="12" X2="12" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="24" X2="24" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                        </Canvas>
                                        <TextBlock Text="Bordure gauche" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Click="OnBorderSelected" Tag="Right" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Style="{StaticResource NumberFontSize}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Canvas Width="24" Height="24" HorizontalAlignment="Left">
                                            <Line X1="0" X2="24" Y1="0" Y2="0" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="24" Y1="12" Y2="12" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="24" Y1="24" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="0" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="12" X2="12" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="24" X2="24" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2"/>
                                        </Canvas>
                                        <TextBlock Text="Bordure droite" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Click="OnBorderSelected" Tag="Bottom" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Style="{StaticResource NumberFontSize}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Canvas Width="24" Height="24" HorizontalAlignment="Left">
                                            <Line X1="0" X2="24" Y1="0" Y2="0" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="24" Y1="12" Y2="12" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="24" Y1="24" Y2="24" Stroke="Black" StrokeThickness="2"/>
                                            <Line X1="0" X2="0" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="12" X2="12" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="24" X2="24" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                        </Canvas>
                                        <TextBlock Text="Bordure inférieure" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Click="OnBorderSelected" Tag="None" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Style="{StaticResource NumberFontSize}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Canvas Width="24" Height="24" HorizontalAlignment="Left">
                                            <Line X1="0" X2="24" Y1="0" Y2="0" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="24" Y1="12" Y2="12" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="24" Y1="24" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="0" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="12" X2="12" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="24" X2="24" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                        </Canvas>
                                        <TextBlock Text="Aucune Bordure" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Click="OnBorderSelected" Tag="All" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Style="{StaticResource NumberFontSize}">
                                    <StackPanel Orientation="Horizontal" Spacing="10" >
                                        <Canvas Width="24" Height="24" HorizontalAlignment="Left">
                                            <Line X1="0" X2="24" Y1="0" Y2="0" Stroke="Black" StrokeThickness="2"/>
                                            <Line X1="0" X2="24" Y1="12" Y2="12" Stroke="Black" StrokeThickness="2"/>
                                            <Line X1="0" X2="24" Y1="24" Y2="24" Stroke="Black" StrokeThickness="2"/>
                                            <Line X1="0" X2="0" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2"/>
                                            <Line X1="12" X2="12" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2"/>
                                            <Line X1="24" X2="24" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2"/>
                                        </Canvas>
                                        <TextBlock Text="Toutes les Bordures" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Click="OnBorderSelected" Tag="Outer" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Style="{StaticResource NumberFontSize}">
                                    <StackPanel Orientation="Horizontal" Spacing="10" >
                                        <Canvas Width="24" Height="24">
                                            <Line X1="0" X2="24" Y1="0" Y2="0" Stroke="Black" StrokeThickness="2"/>
                                            <Line X1="0" X2="24" Y1="12" Y2="12" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="0" X2="24" Y1="24" Y2="24" Stroke="Black" StrokeThickness="2"/>
                                            <Line X1="0" X2="0" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2"/>
                                            <Line X1="12" X2="12" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2" StrokeDashArray="2,3"/>
                                            <Line X1="24" X2="24" Y1="0" Y2="24" Stroke="Black" StrokeThickness="2"/>
                                        </Canvas>
                                        <TextBlock Text="Bordures Extérieures" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                            </StackPanel>
                        </Grid>
                    </Border>
                </Popup>
            </Grid>

            <!-- Couleur de fond -->
            <Grid Grid.Row="1"  Grid.Column="3" Grid.ColumnSpan="5" Margin="5">
                <Border x:Name="BackgroundPickerButton"  Background="White" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" CornerRadius="15" BorderThickness="3" BorderBrush="Black"/>
                <Button Click="OnBackgroundPickerClick" Margin="258,6,6,6" Style="{StaticResource ButtonPersonalizationArrow}">
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Grid Height="24" Width="24" HorizontalAlignment="Right" Margin="-8,0,8,0">
                            <Line X1="0" Y1="6" X2="12" Y2="18" Stroke="Black" StrokeThickness="3"/>
                            <Line X1="12" Y1="18" X2="12" Y2="19" Stroke="Black" StrokeThickness="3"/>
                            <Line X1="12" Y1="18" X2="23" Y2="6" Stroke="Black" StrokeThickness="3"/>
                        </Grid>
                    </Grid>
                </Button>
                <Line Stroke="Black" StrokeThickness="3" X1="253" Y1="6" X2="253" Y2="40"/>
                <Button Click="BackgroundPersonalization" Width="253" Style="{StaticResource ButtonPersonalizationPopup}"/>
                
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left" Width="244" Height="26" Margin="20,0,-20,0" IsHitTestVisible="False">
                    <Border x:Name="SelectedBackgroundIcon" Width="24" Height="24" Background="White" HorizontalAlignment="Left" BorderBrush="Black" BorderThickness="1"/>
                    <TextBlock x:Name="SelectedBackgroundText" Text="Bordure..." FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Popup avec les choix -->
                <Popup x:Name="BackgroundPickerPopup"
                       IsLightDismissEnabled="True"
                       PlacementTarget="{Binding ElementName=BackgroundPickerButton}"
                       DesiredPlacement="Bottom"
                       Opened="BackgroundPickerPopup_Opened"
                       Closed="BackgroundPickerPopup_Closed">
                    
                    <Border x:Name="BackgroundPickerBorder"
                            Margin="0,3,0,-3"
                            BorderBrush="Black"
                            BorderThickness="3"
                            CornerRadius="15"
                            MinWidth="{Binding ActualWidth, ElementName=BackgroundPickerButton}">

                        <Grid>
                            <Border x:Name="BlurredBackgroundContainertransition" CornerRadius="13" Margin="-3" Background="#80FFFFFF"/>
                            
                            <Border x:Name="BlurredBackgroundContainer" CornerRadius="13" Margin="-3">
                                <Border.Background>
                                    <ImageBrush x:Name="BlurredBackgroundBackgroundBrush" Stretch="Fill" />
                                </Border.Background>
                            </Border>

                            <Border Background="#A0FFFFFF" CornerRadius="13"/>

                            <StackPanel Padding="5" Spacing="2" Margin="0,2,0,-2">

                                <!-- Noir -->
                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="6,0,-6,0">
                                    <Button Click="OnBackgroundSelected" Tag="Black" Background="Black" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#1A1A1A" Background="#1A1A1A" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#1D1D1D" Background="#1D1D1D" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#2C2C2C" Background="#2C2C2C" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#404040" Background="#404040" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#565656" Background="#565656" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#6C6C6C" Background="#6C6C6C" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#828282" Background="#828282" Style="{StaticResource ColorButton}"/>
                                </StackPanel>

                                <!-- Blanc-->
                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="6,0,-6,0">
                                    <Button Click="OnBackgroundSelected" Tag="White" Background="White" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#E5E5E5" Background="#E5E5E5" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#CBCBCB" Background="#CBCBCB" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#B2B2B2" Background="#B2B2B2" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#9A9A9A" Background="#9A9A9A" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#828282" Background="#828282" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#6C6C6C" Background="#6C6C6C" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#565656" Background="#565656" Style="{StaticResource ColorButton}"/>
                                </StackPanel>

                                <!-- Rouge -->
                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="6,0,-6,0">
                                    <Button Click="OnBackgroundSelected" Tag="Red" Background="Red" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FF3B1E" Background="#FF3B1E" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FF5835" Background="#FF5835" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FF6E4A" Background="#FF6E4A" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FF8360" Background="#FF8360" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FF9675" Background="#FF9675" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FFA88B" Background="#FFA88B" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FFBAA2" Background="#FFBAA2" Style="{StaticResource ColorButton}"/>
                                </StackPanel>

                                <!-- Bleu-->
                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="6,0,-6,0">
                                    <Button Click="OnBackgroundSelected" Tag="#0084FF" Background="#0084FF" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#438EFF" Background="#438EFF" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#6099FF" Background="#6099FF" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#77A3FF" Background="#77A3FF" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#8CAEFF" Background="#8CAEFF" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#9EB9FF" Background="#9EB9FF" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#B0C5FF" Background="#B0C5FF" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#C0D0FF" Background="#C0D0FF" Style="{StaticResource ColorButton}"/>
                                </StackPanel>

                                <!-- Jaune-->
                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="6,0,-6,0">
                                    <Button Click="OnBackgroundSelected" Tag="Yellow" Background="Yellow" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FFFF6E" Background="#FFFF6E" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FFFF82" Background="#FFFF82" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FFFF95" Background="#FFFF95" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FFFFA7" Background="#FFFFA7" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FFFFB9" Background="#FFFFB9" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FFFFCB" Background="#FFFFCB" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#FFFFDC" Background="#FFFFDC" Style="{StaticResource ColorButton}"/>
                                </StackPanel>

                                <!-- Vert-->
                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="6,0,-6,0">
                                    <Button Click="OnBackgroundSelected" Tag="#00C700" Background="#00C700" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#3FCD30" Background="#3FCD30" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#5CD249" Background="#5CD249" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#73D85F" Background="#73D85F" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#88DD74" Background="#88DD74" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#9AE288" Background="#9AE288" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#ACE89C" Background="#ACE89C" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#BEEDB0" Background="#BEEDB0" Style="{StaticResource ColorButton}"/>
                                </StackPanel>

                                <!-- Violet-->
                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="6,0,-6,0">
                                    <Button Click="OnBackgroundSelected" Tag="Purple" Background="Purple" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#8D298B" Background="#8D298B" Style="{StaticResource ColorButton}"/>
                                    <Button Click="OnBackgroundSelected" Tag="#994197" Background="#994197" Style="{StaticResource ColorButton}"/>

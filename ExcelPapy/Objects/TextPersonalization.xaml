<UserControl
    x:Class="ExcelPapy.Objects.TextPersonalization"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ExcelPapy.Objects"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Border Background="#E6E6E6" CornerRadius="15" BorderBrush="Black" BorderThickness="3">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Police -->
            <ComboBox VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="0" Grid.ColumnSpan="4" Background="White" CornerRadius="15" BorderBrush="Black" BorderThickness="3" FontWeight="DemiBold" FontSize="24" >
                <ComboBoxItem Content="Arial" FontWeight="DemiBold" />
                <ComboBoxItem Content="Calibri" FontWeight="DemiBold" />
                <ComboBoxItem Content="Times New Roman" FontWeight="DemiBold"/>
                <ComboBoxItem Content="Verdana" FontWeight="DemiBold"/>
            </ComboBox>

            <!-- FontSize -->
            <ComboBox VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2" Background="White" CornerRadius="15" BorderBrush="Black" BorderThickness="3" FontWeight="DemiBold" FontSize="24">
                <ComboBoxItem Content="12" FontWeight="DemiBold"/>
                <ComboBoxItem Content="14" FontWeight="DemiBold"/>
                <ComboBoxItem Content="16" FontWeight="DemiBold"/>
                <ComboBoxItem Content="18" FontWeight="DemiBold"/>
                <ComboBoxItem Content="20" FontWeight="DemiBold"/>
            </ComboBox>

            <!-- Bold -->
            <Button Content="G" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" FontWeight="ExtraBold" FontSize="32" Grid.Row="1" Background="Transparent"/>

            <!-- Italique -->
            <Button Content="I" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" FontStyle="Italic" FontWeight="DemiBold" FontSize="36" Grid.Row="1" Grid.Column="1" Background="Transparent"/>

            <!-- Sous-ligné -->
            <Button VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="1" Grid.Column="2" Background="Transparent">
                <Grid>2
                    <TextBlock Text="S" TextDecorations="Underline" FontSize="28" FontWeight="DemiBold" HorizontalTextAlignment="Center" Padding="0,-4,0,4"/>
                    <Line X1="0" Y1="30" X2="20" Y2="30" Stroke="Black" StrokeThickness="3"/>
                </Grid>
            </Button>

            <!-- HorizontalAlignment = Left -->
            <Button VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="1" Grid.Column="3" Background="Transparent">
                <Grid>2
                    <Line X1="0" Y1="4" X2="30" Y2="4" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="12" X2="20" Y2="12" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="20" X2="30" Y2="20" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="28" X2="20" Y2="28" Stroke="Black" StrokeThickness="3"/>
                </Grid>
            </Button>

            <!-- HorizontalAlignment = Center -->
            <Button VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="1" Grid.Column="4" Background="Transparent">
                <Grid>2
                    <Line X1="0" Y1="4" X2="30" Y2="4" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="5" Y1="12" X2="25" Y2="12" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="20" X2="30" Y2="20" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="5" Y1="28" X2="25" Y2="28" Stroke="Black" StrokeThickness="3"/>
                </Grid>
            </Button>

            <!-- HorizontalAlignment = Right -->
            <Button VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5" Grid.Row="1" Grid.Column="5" Background="Transparent">
                <Grid>2
                    <Line X1="0" Y1="4" X2="30" Y2="4" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="10" Y1="12" X2="30" Y2="12" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="0" Y1="20" X2="30" Y2="20" Stroke="Black" StrokeThickness="3"/>
                    <Line X1="10" Y1="28" X2="30" Y2="28" Stroke="Black" StrokeThickness="3"/>
                </Grid>
            </Button>



        </Grid>
    </Border>

</UserControl>
